# Cloudinary unsigned upload — required for the "Post to X / LinkedIn" buttons.
# Create an unsigned upload preset at https://cloudinary.com/console/settings/upload
# Then copy this file to .env.local and fill in your values.

VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name
VITE_CLOUDINARY_UPLOAD_PRESET=your_unsigned_preset_name

# Optional — Cloudinary folder to drop uploads into (e.g. "bwai26-avatars").
VITE_CLOUDINARY_FOLDER=bwai26-avatars
