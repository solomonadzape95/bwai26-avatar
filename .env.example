# --- Cloudinary (client-side, avatar tool only) ---
VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name
VITE_CLOUDINARY_UPLOAD_PRESET=your_unsigned_preset_name
VITE_CLOUDINARY_FOLDER=bwai26-avatars

# --- Supabase ---
# Project URL + anon key are public (used by the browser to upload screenshots).
# The service role key is SECRET — never expose it to the client.
VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...
SUPABASE_URL=https://xxxxxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# --- Gemini (server-side, AI judging) ---
GEMINI_API_KEY=
# Optional: raises GitHub README fetch rate limit from 60/hr to 5000/hr
GITHUB_TOKEN=

# --- Admin + timer ---
# Use 20+ random characters. Required to access /hackathon/admin.
ADMIN_PASSWORD=
# Hackathon countdown length. Must be one of: 10, 30, 120, 2700 (seconds).
# Use 10 or 30 for testing, 2700 (= 45 minutes) for the real event.
HACKATHON_DURATION_SECONDS=2700
